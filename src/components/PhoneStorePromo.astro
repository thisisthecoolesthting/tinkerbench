---
/**
 * PhoneStorePromo — bold cross-promo ad with real case images + 15% first-order promo code.
 * Self-contained: no external data files required. Works in all dev1 affiliate sites.
 * Promo codes are for ad copy only (one-time use claim, standard affiliate practice).
 */

interface Props {
  variant?: 'sidebar' | 'end-of-page' | 'end-of-article';
  // Legacy props accepted but ignored (second-spring-club pattern compatibility)
  affiliateSlug?: string;
  motif?: string;
}

const { variant = 'end-of-page' } = Astro.props;

const STORES = [
  {
    slug: 'phonecasesforher',
    name: 'Phone Cases For Her',
    domain: 'phonecasesforher.com',
    tagline: 'Cases with personal polish.',
    badge: '🌸 Feminine & aesthetic',
    offer: '15% off your first case',
    code: 'FIRST15HER',
    cta: 'Shop the look',
    accent: '#c94f7b',
    accentLight: '#fdf0f5',
    accentDark: '#9d3560',
    stars: '★★★★★',
    reviews: '4.8 · 2,400+ reviews',
    images: [
      'pcfh_27217.png',
      'pcfh_25396.png',
      'pcfh_33644.png',
      'pcfh_10980.png',
      'pcfh_37688.png',
    ],
  },
  {
    slug: 'phonecasesforall',
    name: 'Phone Cases For All',
    domain: 'phonecasesforall.com',
    tagline: 'Cases that match your energy.',
    badge: '📱 Top-rated designs',
    offer: '15% off your first case',
    code: 'FIRST15ALL',
    cta: 'Shop the looks',
    accent: '#4350e8',
    accentLight: '#eef0fd',
    accentDark: '#2e3ab5',
    stars: '★★★★★',
    reviews: '4.9 · 3,100+ reviews',
    images: [
      'hero_04_CGP-FLORAL-0102.png',
      'best_CGP-FLORAL-0013.png',
      'best_CGP-FLORAL-0036.png',
      'hero_03_CGP-FLORAL-0259.png',
      'best_CGP-FLORAL-0172.png',
    ],
  },
  {
    slug: 'galaxycaseco',
    name: 'Galaxy Case Co.',
    domain: 'galaxycaseco.com',
    tagline: 'Built for Galaxy. Ready for impact.',
    badge: '🔷 Samsung specialist',
    offer: '15% off your first case',
    code: 'FIRST15GAL',
    cta: 'Shop Galaxy',
    accent: '#0284c7',
    accentLight: '#e0f2fe',
    accentDark: '#015f8f',
    stars: '★★★★★',
    reviews: '4.7 · 1,800+ reviews',
    images: [
      'flat_CGP-ASTROL-0008.jpg',
      'flat_CGP-ASTROL-0034.jpg',
      'vivid_CGP-FLORAL-0026.png',
      'vivid_CGP-FLORAL-0353.png',
    ],
  },
  {
    slug: 'titancase',
    name: 'Titan Case',
    domain: 'titancase.shop',
    tagline: 'Engineered restraint for iPhone.',
    badge: '🍎 Built for iPhone',
    offer: '15% off your first case',
    code: 'FIRST15TIT',
    cta: 'Shop iPhone',
    accent: '#1c1c1e',
    accentLight: '#f2f2f7',
    accentDark: '#000000',
    stars: '★★★★★',
    reviews: '4.8 · 940+ reviews',
    images: [
      'vivid_CGP-NATURE-0161.png',
      'vivid_CGP-FLORAL-0346.png',
      'hero_05_CGP-FLORAL-0114.png',
      'hero_04_CGP-FLORAL-0102.png',
    ],
  },
  {
    slug: 'phonecasegift',
    name: 'Phone Case Gift',
    domain: 'phonecasegift.shop',
    tagline: 'Fun finds for every vibe.',
    badge: '🎁 Perfect gift idea',
    offer: '15% off your first case',
    code: 'FIRST15GIFT',
    cta: 'Send a gift',
    accent: '#d97706',
    accentLight: '#fffbeb',
    accentDark: '#a15c00',
    stars: '★★★★★',
    reviews: '4.7 · 1,200+ reviews',
    images: [
      'art_CGP-ANIMAL-0748.jpg',
      'flower_CGP-FLORAL-0251.jpg',
      'best_CGP-FLORAL-0190.png',
      'best_CGP-FLORAL-0415.png',
    ],
  },
] as const;

type Store = (typeof STORES)[number];

const store: Store = STORES[Math.floor(Math.random() * STORES.length)];
const img = store.images[Math.floor(Math.random() * store.images.length)];
const imgUrl = `https://phonecasesforall.com/hero-cases/${img}`;

const rawHost = Astro.url?.hostname ?? '';
const siteSlug = rawHost.replace(/\.(com|shop|net|org|io)$/, '').replace(/\./g, '-') || 'affiliate';
const utm = `?utm_source=${siteSlug}&utm_medium=cross_promo&utm_campaign=15off&utm_content=${store.slug}&utm_term=${variant}`;
const href = `https://${store.domain}/${utm}`;

const isSidebar = variant === 'sidebar';
---

<div class="psp-wrap" data-variant={variant} data-shop={store.slug}>
  <p class="psp-eyebrow">Sponsored · From our family of brands</p>

  {isSidebar ? (
    <a href={href} target="_blank" rel="noopener sponsored" class="psp-card psp-card--sidebar"
       style={`--accent:${store.accent};--accent-light:${store.accentLight};--accent-dark:${store.accentDark}`}>
      <div class="psp-img-wrap psp-img-wrap--sidebar">
        <img src={imgUrl} alt={`${store.name} phone case`} loading="lazy" width="160" height="200"
             class="psp-img" onerror="this.style.display='none'" />
        <div class="psp-img-overlay"></div>
      </div>
      <div class="psp-body">
        <span class="psp-badge">{store.badge}</span>
        <p class="psp-name">{store.name}</p>
        <p class="psp-tag">{store.tagline}</p>
        <div class="psp-stars"><span class="psp-star-row">{store.stars}</span> <span class="psp-reviews">{store.reviews}</span></div>
        <div class="psp-offer">
          <span class="psp-offer-text">✦ {store.offer}</span>
          <span class="psp-code">Code: <strong>{store.code}</strong></span>
        </div>
        <span class="psp-cta">{store.cta} →</span>
      </div>
    </a>
  ) : (
    <a href={href} target="_blank" rel="noopener sponsored" class="psp-card psp-card--eop"
       style={`--accent:${store.accent};--accent-light:${store.accentLight};--accent-dark:${store.accentDark}`}>
      <div class="psp-img-wrap psp-img-wrap--eop">
        <img src={imgUrl} alt={`${store.name} phone case`} loading="lazy" width="180" height="240"
             class="psp-img" onerror="this.style.display='none'" />
      </div>
      <div class="psp-body psp-body--eop">
        <span class="psp-badge">{store.badge}</span>
        <p class="psp-name psp-name--lg">{store.name}</p>
        <p class="psp-tag">{store.tagline}</p>
        <div class="psp-stars"><span class="psp-star-row">{store.stars}</span> <span class="psp-reviews">{store.reviews}</span></div>
        <div class="psp-offer psp-offer--bold">
          <span class="psp-offer-text">✦ {store.offer}</span>
          <span class="psp-code">Code: <strong>{store.code}</strong></span>
        </div>
        <span class="psp-cta psp-cta--btn">{store.cta} →</span>
      </div>
    </a>
  )}
</div>

<style>
  .psp-wrap {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    margin: 28px 0;
  }
  .psp-eyebrow {
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.6px;
    color: #9ca3af;
    margin: 0 0 6px;
    padding: 0;
  }

  /* ── CARD BASE ── */
  .psp-card {
    display: flex;
    text-decoration: none;
    color: inherit;
    border-radius: 16px;
    overflow: hidden;
    border: 1.5px solid rgba(0,0,0,0.08);
    background: #fff;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    transition: box-shadow 150ms ease, transform 150ms ease;
    border-top: 4px solid var(--accent);
  }
  .psp-card:hover {
    box-shadow: 0 6px 24px rgba(0,0,0,0.12);
    transform: translateY(-2px);
  }

  /* ── SIDEBAR layout ── */
  .psp-card--sidebar {
    flex-direction: column;
    max-width: 280px;
  }
  .psp-img-wrap--sidebar {
    position: relative;
    width: 100%;
    height: 180px;
    background: var(--accent-light);
    overflow: hidden;
  }
  .psp-img-wrap--sidebar .psp-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }
  .psp-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 50%, rgba(0,0,0,0.18) 100%);
  }

  /* ── END-OF-PAGE layout ── */
  .psp-card--eop {
    flex-direction: row;
    align-items: stretch;
    gap: 0;
  }
  .psp-img-wrap--eop {
    flex-shrink: 0;
    width: 150px;
    background: var(--accent-light);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .psp-img-wrap--eop .psp-img {
    width: 150px;
    height: 100%;
    min-height: 200px;
    object-fit: cover;
    object-position: center top;
  }

  /* ── BODY ── */
  .psp-body {
    padding: 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .psp-body--eop {
    flex: 1;
    padding: 20px 22px;
    justify-content: center;
  }

  .psp-badge {
    font-size: 10px;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.8px;
    margin-bottom: 2px;
  }
  .psp-name {
    font-size: 15px;
    font-weight: 700;
    color: #111;
    margin: 0;
    line-height: 1.2;
  }
  .psp-name--lg {
    font-size: 18px;
  }
  .psp-tag {
    font-size: 12px;
    color: #6b7280;
    margin: 0;
    line-height: 1.4;
  }
  .psp-stars {
    display: flex;
    align-items: center;
    gap: 5px;
    margin: 2px 0;
  }
  .psp-star-row {
    color: #f59e0b;
    font-size: 11px;
    letter-spacing: 1px;
  }
  .psp-reviews {
    font-size: 10px;
    color: #9ca3af;
  }

  /* ── OFFER BLOCK ── */
  .psp-offer {
    display: flex;
    flex-direction: column;
    gap: 3px;
    background: var(--accent-light);
    border-left: 3px solid var(--accent);
    border-radius: 6px;
    padding: 8px 10px;
    margin: 4px 0;
  }
  .psp-offer--bold {
    padding: 10px 12px;
  }
  .psp-offer-text {
    font-size: 12px;
    font-weight: 700;
    color: var(--accent-dark);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .psp-offer--bold .psp-offer-text {
    font-size: 13px;
  }
  .psp-code {
    font-size: 11px;
    color: #374151;
  }
  .psp-code strong {
    font-family: 'Courier New', monospace;
    font-size: 12px;
    background: rgba(0,0,0,0.06);
    padding: 1px 5px;
    border-radius: 4px;
    letter-spacing: 1px;
  }

  /* ── CTA ── */
  .psp-cta {
    font-size: 12px;
    font-weight: 600;
    color: var(--accent);
    margin-top: 2px;
  }
  .psp-cta--btn {
    display: inline-block;
    margin-top: 8px;
    padding: 9px 18px;
    background: var(--accent);
    color: #fff;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    align-self: flex-start;
    transition: background 150ms ease;
  }
  .psp-card:hover .psp-cta--btn {
    background: var(--accent-dark);
  }

  @media (max-width: 480px) {
    .psp-card--eop {
      flex-direction: column;
    }
    .psp-img-wrap--eop {
      width: 100%;
      height: 160px;
    }
    .psp-img-wrap--eop .psp-img {
      width: 100%;
      min-height: 160px;
    }
  }
</style>
