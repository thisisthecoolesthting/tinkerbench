---
import { FALLBACK_SVG, productImageCandidates } from '@/utils/product-image';

export interface Props {
  slug: string;
  asin: string;
  imageUrl?: string | null;
  alt: string;
  class?: string;
  loading?: 'eager' | 'lazy';
  containerClass?: string;
}

const {
  slug,
  asin,
  imageUrl,
  alt,
  class: imgClass = 'max-h-72 w-full object-contain',
  loading = 'lazy',
  containerClass = '',
} = Astro.props;

const sources = productImageCandidates(slug, asin, imageUrl);
const primary = sources[0];
const fallbacks = sources.slice(1);
---

<img
  src={primary}
  alt={alt}
  loading={loading}
  class:list={[imgClass, containerClass]}
  data-fallbacks={fallbacks.join('|')}
  onerror={`(function(img){var q=img.getAttribute('data-fallbacks');if(!q){img.src='${FALLBACK_SVG}';return;}var n=q.split('|').filter(Boolean);if(!n.length){img.onerror=null;return;}img.src=n.shift();img.setAttribute('data-fallbacks',n.join('|'));})(this)`}
/>
