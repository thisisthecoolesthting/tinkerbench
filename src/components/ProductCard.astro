---
// Compact product card for listing pages and "related picks" sections.
// Uses the card-level display contract: short human title (data.cardTitle or
// trimmed fallback), one-line "why we picked it" (data.cardPick), consistent
// square aspect on cream bg, always-show rating + review count when present.
// Broken image URLs fall back to a neutral placeholder (onerror handler).

import type { CollectionEntry } from 'astro:content';
import { amazonAffiliateUrl } from '@/utils/related-products';
import { DEFAULT_ASSOCIATE_TAG } from '@/utils/amazon-affiliate';
import ProductImage from '@/components/ProductImage.astro';

export interface Props {
  product: CollectionEntry<'products'>;
}

const { product } = Astro.props;
const { data } = product as any;
const associateTag = import.meta.env.PUBLIC_ASSOCIATE_TAG ?? DEFAULT_ASSOCIATE_TAG;
const affiliateHref = amazonAffiliateUrl(product, associateTag);
const url = `/products/${product.slug}`;

// Prefer hand-curated short title; fall back to word-boundary trim of raw title.
// Never truncate mid-word — cut at the last space before the limit.
const rawTitle = data.title || '';
function wordTrim(src: string, max: number): string {
  if (src.length <= max) return src;
  const slice = src.slice(0, max);
  const lastSpace = slice.lastIndexOf(' ');
  const base = lastSpace > 20 ? slice.slice(0, lastSpace) : slice;
  return base.replace(/[,\-\s]+$/, '') + '…';
}
const shortTitle = (data.cardTitle && data.cardTitle.trim())
  ? data.cardTitle.trim()
  : wordTrim(rawTitle, 52);

// One-line "Why we picked it" — optional, hand-curated per product.
const pickLine = (data.cardPick && data.cardPick.trim()) ? data.cardPick.trim() : '';
const asin = String(data.asin || product.slug.split('-')[0] || '').toUpperCase();
---
<a
  href={affiliateHref}
  target="_blank"
  rel="nofollow noopener sponsored"
  class="group block h-full w-full min-w-0 rounded-3xl border border-cream-200/70 bg-white shadow-soft
         hover:shadow-soft-lg hover:-translate-y-1
         transition-all duration-300 ease-out no-underline overflow-hidden"
>
  <div class="aspect-square bg-cream-100 flex items-center justify-center overflow-hidden">
    <ProductImage
      slug={product.slug}
      asin={asin}
      imageUrl={data.imageUrl}
      alt={shortTitle}
      loading="lazy"
      class="w-full h-full object-contain p-5 group-hover:scale-[1.04] transition-transform duration-500 ease-out"
    />
  </div>
  <div class="p-5 space-y-1.5">
    <h3 class="text-base font-semibold text-ink-900 leading-snug !mt-0 group-hover:text-terracotta-600 transition-colors duration-200">
      {shortTitle}
    </h3>
    {pickLine && (
      <p class="text-xs text-ink-500 leading-snug italic">
        {pickLine}
      </p>
    )}
    {(data.price || data.rating) && (
      <div class="flex items-center justify-between text-sm text-ink-700 pt-1">
        {data.price ? (
          <span class="font-semibold">${data.price.toFixed(2)}</span>
        ) : <span />}
        {data.rating && (
          <span class="text-ink-500">
            &#9733; {data.rating.toFixed(1)}
            {data.reviewCount ? ` · ${data.reviewCount.toLocaleString()}` : ''}
          </span>
        )}
      </div>
    )}
  </div>
  <div class="px-5 pb-5 pt-1">
    <span class="block w-full text-center bg-terracotta-500 hover:bg-terracotta-600
                 text-cream-50 font-mono text-[11px] tracking-[0.12em] uppercase
                 px-4 py-2.5 rounded-full transition-colors">
      View on Amazon ↗
    </span>
  </div>
</a>
