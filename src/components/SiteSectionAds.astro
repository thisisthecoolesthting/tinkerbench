---
/**
 * Section pages: top leaderboard (central ad-injection system) + text links.
 * The header band renders a single home-top slot via inject.js/manifest.json.
 * NO square CaseAdSlot composites. No cad-composite anywhere.
 */
import PhoneCaseFamilyTextLinks from '@/components/PhoneCaseFamilyTextLinks.astro';
import type { SectionPage } from '@/lib/section-page';

export type { SectionPage };

export interface Props {
  page: SectionPage;
  variant?: 'header' | 'footer' | 'both';
  compact?: boolean;
}

const { page, variant = 'both', compact = false } = Astro.props;

const showHeader = variant === 'header' || variant === 'both';
const showFooter  = variant === 'footer' || variant === 'both';

// SSR fallback href — inject.js replaces at runtime with weighted rotation
const fallbackHref =
  'https://phonecasesforall.com/?utm_source=tinkerbench&utm_medium=leaderboard&utm_campaign=15off&utm_content=728x90_home-top';
---

{showHeader && (
  <div
    class:list={[
      'max-w-site mx-auto px-4 sm:px-6 lg:px-8 not-prose section-ads-header',
      compact ? 'py-1 md:py-1.5 section-ads-header--compact' : 'py-1.5 md:py-2',
    ]}
    role="complementary"
    aria-label="Sponsored offer"
  >
    <div
      data-ad-slot="home-top"
      class="home-top-slot not-prose"
      role="complementary"
      aria-label="Sponsored"
    >
      <p class="adn-eyebrow">Sponsored</p>
      <a
        href={fallbackHref}
        target="_blank"
        rel="sponsored noopener"
        class="home-top-fallback-link"
      >
        <span class="home-top-store">Phone Cases For All</span>
        <span class="home-top-sep" aria-hidden="true"> &mdash; </span>
        <span class="home-top-body">50,000+ designs &middot; ships in 2&nbsp;days &mdash; 15%&nbsp;off code&nbsp;<strong>FIRST15ALL</strong></span>
        <span class="home-top-cta" aria-hidden="true"> &rarr;</span>
      </a>
    </div>
  </div>
)}

{showFooter && (
  <div class="max-w-site mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-10 border-t border-cream-200/80">
    <div class="max-w-3xl mx-auto">
      <PhoneCaseFamilyTextLinks placement={`${page}-section-footer`} />
    </div>
  </div>
)}

<style>
  .section-ads-header--compact :global(.adn-eyebrow),
  .section-ads-header :global(.adn-eyebrow) {
    margin: 0.15rem 0 3px;
  }

  .home-top-slot {
    width: 100%;
    padding: 6px 8px 7px;
    border-radius: 8px;
    background: #f9f5f0;
    border: 1px solid rgba(0,0,0,0.07);
  }

  .home-top-fallback-link {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0 6px;
    text-decoration: none;
    color: inherit;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 0.82rem;
    line-height: 1.45;
  }
  .home-top-fallback-link:hover .home-top-store { text-decoration: underline; }

  .home-top-store { font-weight: 700; color: #111827; }
  .home-top-sep   { color: #9ca3af; }
  .home-top-body  { color: #374151; }
  .home-top-cta   { color: #4350e8; font-weight: 600; white-space: nowrap; }

  @media (max-width: 480px) {
    .home-top-sep { display: none; }
    .home-top-fallback-link { gap: 2px 4px; }
  }
</style>
