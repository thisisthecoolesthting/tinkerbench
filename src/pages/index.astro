---
// SPINE template homepage — canary deploy of the spine architecture.
// Pinterest-passable editorial layout with 2:3 hero, 4-pillar grid,
// 3-product comparison row, 6-card latest articles, dark author trust block,
// newsletter, methodology disclosure strip. All sections use existing
// Tailwind palette classes — per-site palette differentiation lives in
// tailwind.config.mjs. Defensive defaults handle missing data keys
// (about / categories / defaultAuthorSlug / persona).

import CompliantLayout from '@/layouts/CompliantLayout.astro';
import SiteSectionAds from '@/components/SiteSectionAds.astro';
import { getCollection } from 'astro:content';
import CuratedAmazonCard from '@/components/CuratedAmazonCard.astro';
import NewsletterForm from '@/components/NewsletterForm.astro';
import HeroCompact from '@/components/HeroCompact.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import home from '@/data/brand.config.json';
import { HOMEPAGE_COMPARE_PICKS } from '@/lib/site-amazon-registry.mjs';

const h = home.homepage;
const b = home.brand;

// ---------- Defensive helpers (refillwatch's brand.config has fewer keys than SSC's) ----------
const homeX = home as Record<string, any>;
const dmeta = homeX.defaultMetaDescription || (b as any).taglineShort || '';
const authorSlug = homeX.defaultAuthorSlug || '_default';
const siteYmyl = homeX.persona?.ymyl === true;
const editorPseudonym = homeX.persona?.pseudonymHint || homeX.persona?.name || '';
const aboutHeadline = homeX.about?.headline || `Why ${b.shortName || b.fullName} exists`;
const aboutBody = homeX.about?.body
  || (b as any).taglineShort
  || `We translate confusing ${(homeX.categories?.[0] || 'category')} chatter into practical, evidence-based notes.`;
const heroCategories: string[] = Array.isArray(homeX.categories) && homeX.categories.length
  ? homeX.categories
  : ['household refills', 'subscription creep', 'printer ink', 'grocery staples'];

// ---------- Content collection joins ----------
const allProducts = await getCollection('products', ({ data }) => data.status === 'published');
const completeProducts = allProducts.filter((p) => {
  const d = p.data;
  const hasImage =
    (d.imageUrl && !d.imageUrl.includes('example') && !d.imageUrl.startsWith('data:')) ||
    Boolean(d.asin && /^[A-Z0-9]{10}$/i.test(String(d.asin)));
  const hasPrice = typeof d.price === 'number' && d.price > 0;
  const hasRating = typeof d.rating === 'number' && d.rating > 0;
  return hasImage && hasPrice && hasRating;
});
const compareRow = HOMEPAGE_COMPARE_PICKS;
const heroProducts = completeProducts.slice(0, 3);

const allPillars = await getCollection('pillars', ({ data }) => data.status === 'published');
const pillarFour = allPillars
  .sort((a, b) => +new Date(b.data.publishedAt) - +new Date(a.data.publishedAt))
  .slice(0, 4);

/** Prefer real pillar guides; fall back to category tiles — never render an empty grid. */
const pillarGridEntries =
  pillarFour.length > 0 ? pillarFour : heroCategories.slice(0, 4);

const allArticles = await getCollection('articles', ({ data }) => data.status === 'published');
const latestSix = allArticles
  .sort((a, b) => +new Date(b.data.publishedAt) - +new Date(a.data.publishedAt))
  .slice(0, 6);

/** Count articles related to a pillar guide or category tile (tags / title overlap). */
function countRelatedArticles(entry: unknown, isPillar: boolean): number {
  if (isPillar) {
    const pillar = entry as { slug: string; data: { title?: string; tags?: string[] } };
    const pillarTags = (pillar.data.tags || []).map((t) => t.toLowerCase());
    const titleHint = (pillar.data.title || pillar.slug).toLowerCase();
    return allArticles.filter((a) => {
      const tags = (a.data.tags || []).map((t: string) => t.toLowerCase());
      if (a.data.pillarSlug === pillar.slug) return true;
      return tags.some(
        (t) =>
          pillarTags.some((pt) => t.includes(pt) || pt.includes(t)) ||
          titleHint.includes(t) ||
          t.split(' ').some((w) => w.length > 4 && titleHint.includes(w)),
      );
    }).length;
  }
  const category = String(entry).toLowerCase();
  const needle = category.split(/\s+/)[0];
  return allArticles.filter((a) => {
    const tags = (a.data.tags || []).map((t: string) => t.toLowerCase());
    const title = (a.data.title || '').toLowerCase();
    return tags.some((t) => t.includes(needle) || category.includes(t)) || title.includes(needle);
  }).length;
}

// ---------- Trust line ----------
const computedTrust = `${allArticles.length} articles · ${allPillars.length} in-depth guides · ${completeProducts.length} products tracked`;
const trustLineDisplay = (h.trustLine && String(h.trustLine).trim()) || computedTrust;

// ---------- Pinterest pin variants ----------
const pinThumbVariants = [
  'bg-gradient-to-b from-sage-400/40 to-sage-600/55',
  'bg-gradient-to-b from-cream-200 to-terracotta-400/35',
  'bg-gradient-to-b from-terracotta-400/35 to-rose-deep/55',
  'bg-gradient-to-b from-cream-100 to-sage-400/35',
  'bg-gradient-to-b from-ink-900/95 to-ink-700',
  'bg-gradient-to-b from-cream-200 to-sage-500/45',
];

const heroStatCount = completeProducts.length;
const heroStatLabel = heroStatCount === 1 ? 'product tracked' : 'products tracked';

const dataStats = [
  { num: '18%', label: 'Staple price creep', sub: 'Average household refill hike since 2022.' },
  { num: '$420', label: 'Annual overspend', sub: 'On repeat buys when you miss shrinkflation.' },
  { num: `${completeProducts.length || '50'}+`, label: 'Products tracked', sub: 'Water, detergent, ink, pet food, subscriptions.' },
];

const trustItems = [
  { label: 'Independent watchdog', icon: 'shield' as const },
  { label: 'Weekly price checks', icon: 'clock' as const },
  { label: 'No retailer sponsorships', icon: 'ban' as const },
];
---

<CompliantLayout title={b.fullName} description={dmeta} sectionAds="home" sectionAdsCompact sectionAdsFooter={false}>

  {/* ============ 1. HERO — compact watchdog band ============ */}
  <HeroCompact
    eyebrow={h.eyebrow}
    h1={h.h1}
    subhead={h.subhead}
    ctaPrimaryHref={h.ctaPrimaryHref}
    ctaPrimaryLabel={h.ctaPrimaryLabel}
    ctaSecondaryHref={h.ctaSecondaryHref}
    ctaSecondaryLabel={h.ctaSecondaryLabel}
    bullets={['No retailer sponsorships', 'Weekly price checks', `${allArticles.length}+ articles tracked`]}
    stats={dataStats}
    products={heroProducts}
    articleCount={allArticles.length}
    gradient="bg-[radial-gradient(50%_80%_at_100%_0%,rgba(180,83,9,.14),transparent_55%),radial-gradient(40%_50%_at_0%_100%,rgba(55,65,81,.22),transparent_60%)]"
    snapshot={{
      panelLabel: 'Price watchlist',
      panelAriaLabel: 'Household staple price snapshot',
      trackedSuffix: 'articles tracked',
      footerNote: 'Shrinkflation alerts · refill swaps · no pay-to-play',
      footerHref: '/pillars/household-refill-buying-guide',
      footerLinkText: 'Refill buying guide →',
      productPlaceholder: 'Item',
    }}
    heroImageUrl={h.heroImageUrl}
    heroVideoUrl={(h as { heroVideoUrl?: string }).heroVideoUrl}
    heroBadge="Consumer price watchdog"
    heroCaption="We track maker gear and resin printers on repeat — and flag when workshop bundles inflate the basics you print every week."
    heroAlt="Resin 3D printer and miniatures in a maker workspace"
    rightPanel="image"
  />

  <TrustStrip trustLine={trustLineDisplay} items={trustItems} />

  {/* ============ 3. PILLAR GRID ============ */}
  {pillarGridEntries.length > 0 && (
    <section class="max-w-6xl mx-auto px-5 py-8 md:py-10">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-5 mb-8">
        <div>
          <p class="font-mono text-[11px] tracking-[0.18em] uppercase text-terracotta-600 font-medium mb-2">Start here</p>
          <h2 class="font-display text-3xl md:text-4xl text-ink-900 leading-tight !mt-0 max-w-[18ch]">
            Pillars we track every week.
          </h2>
        </div>
        <p class="text-sm text-ink-700 max-w-[28ch]">
          Each pillar is its own watchlist: explainer → tracked products → cheaper swap.
          Three clicks to the answer.
        </p>
      </div>
      <div class={`grid grid-cols-1 sm:grid-cols-2 gap-4 ${pillarGridEntries.length >= 4 ? 'lg:grid-cols-4' : 'lg:grid-cols-3'}`}>
        {pillarGridEntries.map((entry: any, idx: number) => {
          const isPillar = !!entry?.slug && !!entry?.data;
          const tints = [
            'bg-gradient-to-b from-cream-100 to-cream-50',
            'bg-gradient-to-b from-sage-400/15 to-cream-50',
            'bg-gradient-to-b from-terracotta-400/15 to-cream-50',
            'bg-gradient-to-b from-cream-200 to-cream-50',
          ];
          const num = String(idx + 1).padStart(2, '0');
          const title = isPillar ? entry.data.title : (entry as string).charAt(0).toUpperCase() + (entry as string).slice(1);
          const excerpt = isPillar ? entry.data.excerpt : `Tracked products and price-history for ${entry}.`;
          const href = isPillar ? `/pillars/${entry.slug}` : `/articles?subtopic=${encodeURIComponent(String(entry))}`;
          const articleCount = countRelatedArticles(entry, isPillar);
          const firstWord = String(entry?.data?.title || entry || '').split(' ')[0];
          return (
            <a href={href} class={`group no-underline relative overflow-hidden rounded-xl border border-cream-200 p-6 min-h-[240px] flex flex-col transition-all hover:-translate-y-1 hover:shadow-soft-lg hover:border-terracotta-400 ${tints[idx % tints.length]}`}>
              <p class="font-display text-sm text-terracotta-600">{num} · {firstWord}</p>
              <h3 class="font-display text-xl text-ink-900 !mt-2 leading-snug max-w-[14ch]">
                {title}
              </h3>
              <p class="text-sm text-ink-700 mt-2.5 leading-relaxed">
                {excerpt}
              </p>
              <span class="font-mono text-[11px] tracking-[0.1em] uppercase text-ink-900 mt-auto pt-4 group-hover:text-terracotta-600">
                {articleCount > 0 ? `${articleCount} related articles` : `${allArticles.length} articles`}
                <span class="text-terracotta-500"> →</span>
              </span>
            </a>
          );
        })}
      </div>
    </section>
  )}

  {/* ============ 4. LATEST STRIP ============ */}
  {latestSix.length > 0 && (
    <section class="max-w-6xl mx-auto px-5 py-12 md:py-14">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-5 mb-8">
        <div>
          <p class="font-mono text-[11px] tracking-[0.18em] uppercase text-terracotta-600 font-medium mb-2">Latest from the desk</p>
          <h2 class="font-display text-3xl md:text-4xl text-ink-900 !mt-0 leading-tight max-w-[20ch]">
            Six things we published recently.
          </h2>
        </div>
        <a href="/articles" class="font-mono text-[11.5px] tracking-[0.08em] uppercase text-ink-900 border-b border-terracotta-500 pb-0.5 no-underline hover:text-terracotta-600 whitespace-nowrap">
          All {allArticles.length} articles →
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {latestSix.map((a, i) => (
          <a href={`/articles/${a.slug}`} class="group no-underline block bg-white border border-cream-200 rounded-xl overflow-hidden hover:shadow-soft-lg hover:-translate-y-1 hover:border-terracotta-400 transition-all">
            <div class={`relative aspect-[2/3] overflow-hidden ${a.data.heroImage ? '' : pinThumbVariants[i % pinThumbVariants.length]}`}>
              {a.data.heroImage ? (
                <img src={a.data.heroImage} alt={a.data.title} loading="lazy"
                     class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-500" />
              ) : (
                <div class={`absolute inset-0 p-6 flex flex-col justify-between ${i === 4 ? 'text-cream-50' : 'text-ink-900'}`}>
                  <span class={`font-mono text-[10.5px] tracking-[0.16em] uppercase ${i === 4 ? 'text-terracotta-400' : 'text-terracotta-600'}`}>
                    {(a.data.tags?.[0] || 'Article')} · {a.data.readingTime || '8'} min read
                  </span>
                  <h3 class={`font-display text-2xl leading-[1.08] max-w-[12ch] !mt-0 ${i === 4 ? 'text-cream-50' : 'text-ink-900'}`}>
                    {a.data.title}
                  </h3>
                </div>
              )}
            </div>
            <div class="p-5 flex flex-col gap-2.5">
              <p class="font-mono text-[10.5px] tracking-[0.14em] uppercase text-terracotta-600">
                {a.data.tags?.[0] || 'Editorial'}
              </p>
              <h3 class="font-display text-lg text-ink-900 !mt-0 leading-snug group-hover:text-terracotta-600 transition-colors">
                {a.data.title}
              </h3>
              <div class="flex items-center gap-2.5 mt-auto pt-3 border-t border-cream-200 text-xs text-ink-500">
                <span class="inline-grid place-items-center w-6 h-6 rounded-full bg-sage-500 text-cream-50 font-display font-semibold text-[11px]">
                  {(editorPseudonym?.[0] || b.fullName?.[0] || 'E').toUpperCase()}
                </span>
                <span>{editorPseudonym || 'Editorial'} · {new Date(a.data.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  {/* ============ 5. COMPARISON ROW ============ */}
  {compareRow.length >= 1 && (
    <section class="bg-gradient-to-b from-cream-50 to-cream-100 border-y border-cream-200">
      <div class="max-w-6xl mx-auto px-5 py-12 md:py-14">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-5 mb-6">
          <div>
            <p class="font-mono text-[11px] tracking-[0.18em] uppercase text-terracotta-600 font-medium mb-2">Tracked this week</p>
            <h2 class="font-display text-3xl md:text-4xl text-ink-900 !mt-0 leading-tight max-w-[24ch]">
              Three products, three price tiers, one verdict.
            </h2>
          </div>
          <p class="text-sm text-ink-700 max-w-[34ch]">
            We watch the price history. Below: the cheapest defensible answer, the smart-buy
            middle, and the splurge at each price point.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          {compareRow.map((p, i) => (
            <div class="relative">
              {i === 1 && (
                <span class="absolute z-10 top-3 left-3 bg-terracotta-500 text-white font-mono text-[10px] tracking-[0.14em] uppercase px-2.5 py-1 rounded">
                  Editors' Choice
                </span>
              )}
              {i === 0 && (
                <span class="absolute z-10 top-3 left-3 bg-ink-900 text-cream-50 font-mono text-[10px] tracking-[0.14em] uppercase px-2.5 py-1 rounded">
                  Budget pick
                </span>
              )}
              {i === 2 && (
                <span class="absolute z-10 top-3 left-3 bg-sage-600 text-cream-50 font-mono text-[10px] tracking-[0.14em] uppercase px-2.5 py-1 rounded">
                  Premium
                </span>
              )}
              <CuratedAmazonCard pick={p} />
            </div>
          ))}
        </div>

        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3 mt-8 pt-6 border-t border-dashed border-cream-200">
          <p class="text-sm text-ink-700 max-w-[60ch]">
            <strong class="text-ink-900">How we research:</strong> price-history checks via Keepa,
            cross-retailer verification weekly, raw data on the methodology page.
          </p>
          <a href="/methodology/" class="font-mono text-[11.5px] tracking-[0.08em] uppercase text-ink-900 border-b border-terracotta-500 pb-0.5 no-underline hover:text-terracotta-600 whitespace-nowrap">
            See the rig →
          </a>
        </div>
      </div>
    </section>
  )}

  {/* ============ 6. AUTHOR TRUST BLOCK ============ */}
  <section class="relative bg-ink-900 text-cream-50 py-16 md:py-20 overflow-hidden">
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none
                                    bg-[radial-gradient(50%_60%_at_18%_50%,rgba(220,38,38,.18),transparent_70%)]"></div>
    <div class="relative max-w-6xl mx-auto px-5 grid md:grid-cols-[280px_1fr] gap-10 md:gap-14 items-start">
      <a href={`/authors/${authorSlug}/`} class="block no-underline">
        <div class="aspect-[4/5] rounded-2xl overflow-hidden bg-gradient-to-br from-terracotta-400 to-terracotta-600 shadow-soft-lg relative">
          <img
            src={`/authors/${authorSlug}.svg`}
            onerror="this.style.display='none'"
            alt={editorPseudonym || b.fullName}
            loading="lazy"
            class="absolute inset-0 w-full h-full object-cover"
          />
          <div class="absolute inset-0 grid place-items-center">
            <span class="font-display font-semibold text-7xl text-cream-50/85">
              {(editorPseudonym?.[0] || b.fullName?.[0] || 'E').toUpperCase()}
            </span>
          </div>
          <span class="absolute bottom-3.5 right-3.5 bg-cream-50 text-ink-900 font-mono text-[10px] tracking-[0.12em] uppercase px-2.5 py-1 rounded">
            Editor-in-chief
          </span>
        </div>
      </a>
      <div>
        <p class="font-mono text-[11px] tracking-[0.18em] uppercase text-terracotta-400 font-medium">About the desk</p>
        <h2 class="font-display text-3xl md:text-4xl !mt-3 leading-tight text-cream-50">
          {aboutHeadline}
        </h2>
        <p class="text-cream-50/80 text-base md:text-lg leading-relaxed mt-5 max-w-[56ch]">
          {aboutBody}
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 md:gap-7 mt-8 pt-8 border-t border-cream-50/15">
          <div>
            <p class="font-mono text-[10.5px] tracking-[0.14em] uppercase text-terracotta-400">Articles published</p>
            <p class="font-display text-3xl text-cream-50 mt-1.5 leading-none">{allArticles.length}</p>
            <p class="text-sm text-cream-50/65 mt-1.5">All bylined, dated, reviewed quarterly.</p>
          </div>
          <div>
            <p class="font-mono text-[10.5px] tracking-[0.14em] uppercase text-terracotta-400">Products tracked</p>
            <p class="font-display text-3xl text-cream-50 mt-1.5 leading-none">{completeProducts.length}</p>
            <p class="text-sm text-cream-50/65 mt-1.5">Independent watchlist — every price logged.</p>
          </div>
          <div>
            <p class="font-mono text-[10.5px] tracking-[0.14em] uppercase text-terracotta-400">In-depth guides</p>
            <p class="font-display text-3xl text-cream-50 mt-1.5 leading-none">{allPillars.length}</p>
            <p class="text-sm text-cream-50/65 mt-1.5">Pillar topics, updated as the field changes.</p>
          </div>
        </div>

        <div class="flex flex-wrap gap-3 mt-9">
          <a href="/methodology/" class="btn-primary no-underline">
            Read our methodology <span aria-hidden="true" class="ml-2">→</span>
          </a>
          <a href={`/authors/${authorSlug}/`} class="inline-flex items-center justify-center rounded-full px-7 py-3 font-semibold text-base border border-cream-50/40 text-cream-50 transition-all hover:bg-cream-50 hover:text-ink-900 no-underline">
            More about the editor
          </a>
        </div>
      </div>
    </div>
  </section>

  <SiteSectionAds page="home" variant="footer" />

  {/* ============ 7. NEWSLETTER ============ */}
  <section class="max-w-3xl mx-auto px-5 py-10 md:py-12">
    <NewsletterForm
      variant="hero"
      title="TinkerBench weekly"
      subtitle="One shrinkflation alert, one smarter swap, one price check — every week. No spam."
      cta="Get price alerts"
    />
  </section>

  {/* ============ 8. METHODOLOGY DISCLOSURE STRIP ============ */}
  <section class="bg-sage-400/15 border-y border-cream-200 py-12">
    <div class="max-w-6xl mx-auto px-5
                grid md:grid-cols-[auto_1fr_auto] gap-6 md:gap-9 items-center">
      <div class="grid place-items-center w-16 h-16 rounded-full bg-sage-500 text-cream-50 font-display text-2xl font-semibold">§</div>
      <div>
        <h3 class="font-display text-xl md:text-2xl text-ink-900 !mt-0 mb-1">
          Standards, disclosures, and how we make money.
        </h3>
        <p class="text-sm md:text-[15px] text-ink-700 max-w-[60ch]">
          Affiliate-link disclosure, research protocol, conflict-of-interest policy, and our
          correction log. All on one page. Read before you trust the rest.
        </p>
      </div>
      <a href="/methodology/" class="btn-primary no-underline whitespace-nowrap">
        Read standards <span aria-hidden="true" class="ml-2">→</span>
      </a>
    </div>
  </section>

</CompliantLayout>
