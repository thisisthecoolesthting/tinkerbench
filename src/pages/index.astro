---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import ProductCard from '@/components/ProductCard.astro';
import NewsletterForm from '@/components/NewsletterForm.astro';
import home from '@/data/spawn-home.json';

const h = home.homepage;
const b = home.brand;
const dmeta = (home as { defaultMetaDescription?: string }).defaultMetaDescription || b.taglineShort;
const authorSlug = (home as { defaultAuthorSlug: string }).defaultAuthorSlug;
const siteYmyl = (home as { persona?: { ymyl?: boolean } }).persona?.ymyl === true;

const allProducts = await getCollection('products', ({ data }) => data.status === 'published');

// Homepage "top picks" must pass the display bar — real image, real price, real rating.
// This mirrors the /products page filter; a product that fails here never ships.
const completeProducts = allProducts.filter((p) => {
  const d = p.data;
  const hasImage = d.imageUrl && !d.imageUrl.includes('example') && !d.imageUrl.startsWith('data:');
  const hasPrice = typeof d.price === 'number' && d.price > 0;
  const hasRating = typeof d.rating === 'number' && d.rating > 0;
  return hasImage && hasPrice && hasRating;
});

const featured = completeProducts
  .sort((a, b) => (b.data.score ?? 0) - (a.data.score ?? 0))
  .slice(0, 6);

const allPillars = await getCollection('pillars', ({ data }) => data.status === 'published');
const featuredPillars = allPillars
  .sort((a, b) => +new Date(b.data.publishedAt) - +new Date(a.data.publishedAt))
  .slice(0, 3);

const allArticles = await getCollection('articles', ({ data }) => data.status === 'published');
const recentArticles = allArticles
  .sort((a, b) => +new Date(b.data.publishedAt) - +new Date(a.data.publishedAt))
  .slice(0, 3);

// Concrete, factual trust line — numbers beat adjectives.
// Computed fresh from the content collection so it stays true as we grow.
const trustLine =
  `${allArticles.length} articles · ${allPillars.length} in-depth guides · ${completeProducts.length} products reviewed`;

const trustLineDisplay = (h.trustLine && String(h.trustLine).trim()) || trustLine;
---

<BaseLayout
  title={b.fullName}
  description={dmeta}
>
  <section class="relative pt-6 md:pt-10">
    <div class="max-w-6xl mx-auto px-5">
      <div class="relative overflow-hidden rounded-[2.5rem] md:rounded-[3.5rem] shadow-soft">
        <div class="absolute inset-0">
          <img
            src={h.heroImageUrl}
            alt=""
            class="w-full h-full object-cover object-center"
            loading="eager"
          />
        </div>
        <div
          class="absolute inset-0 bg-gradient-to-b from-black/55 via-black/30 to-black/40"
          aria-hidden="true"
        ></div>

        <div class="relative max-w-4xl mx-auto px-6 py-12 md:py-16 text-center">
          <p class="text-terracotta-600 font-semibold uppercase tracking-[0.18em] text-xs md:text-sm mb-5">
            {h.eyebrow}
          </p>
          <h1 class="font-display text-4xl md:text-5xl text-white mb-5 leading-[1.08] drop-shadow-lg tracking-tight">
            {h.h1}
          </h1>
          <p class="text-base md:text-lg text-cream-50/90 max-w-[52ch] mx-auto leading-relaxed drop-shadow mb-7">
            {h.subhead}
          </p>
          <div class="flex flex-wrap justify-center gap-3">
            <a href={h.ctaPrimaryHref} class="btn-primary no-underline">{h.ctaPrimaryLabel}</a>
            <a href={h.ctaSecondaryHref} class="btn-secondary no-underline">{h.ctaSecondaryLabel}</a>
          </div>
          <p class="mt-5 text-xs text-ink-500 uppercase tracking-[0.1em]">
            {trustLineDisplay}
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-10 md:py-14">
    <div class="max-w-6xl mx-auto px-5">
      <div class="bg-white rounded-[2.5rem] md:rounded-[3rem] shadow-soft px-6 md:px-10 py-12 md:py-14
                  grid md:grid-cols-3 gap-10 md:gap-6 text-center">
        <div class="px-4">
          <div class="text-terracotta-600 text-3xl md:text-4xl font-display mb-3 leading-none">Honest</div>
          <p class="text-sm text-ink-700 leading-relaxed max-w-[30ch] mx-auto">
            No sponsored reviews. We say skip it when we mean it.
          </p>
        </div>
        <div class="px-4 md:border-x border-cream-200/70">
          <div class="text-terracotta-600 text-3xl md:text-4xl font-display mb-3 leading-none">Researched</div>
          <p class="text-sm text-ink-700 leading-relaxed max-w-[30ch] mx-auto">
            {siteYmyl
              ? 'Peer-reviewed sources where they apply; we flag when evidence is limited.'
              : 'Sources cited where they matter, with links you can check yourself.'}
          </p>
        </div>
        <div class="px-4">
          <div class="text-terracotta-600 text-3xl md:text-4xl font-display mb-3 leading-none">Specific</div>
          <p class="text-sm text-ink-700 leading-relaxed max-w-[30ch] mx-auto">
            Every recommendation tied to a specific problem at a specific price.
          </p>
        </div>
      </div>
    </div>
  </section>

  {featuredPillars.length > 0 && (
    <section class="max-w-6xl mx-auto px-6 py-20">
      <div class="flex items-end justify-between mb-10">
        <div>
          <p class="text-terracotta-600 text-xs uppercase tracking-[0.2em] font-semibold mb-2">Start here</p>
          <h2 class="font-display text-3xl md:text-4xl text-ink-900 leading-tight">In-depth guides</h2>
        </div>
        <a href="/pillars" class="text-sm text-terracotta-600 font-medium whitespace-nowrap hover:underline">All guides →</a>
      </div>
      <div class="grid md:grid-cols-3 gap-6 md:gap-8">
        {featuredPillars.map((p) => (
          <a href={`/pillars/${p.slug}`} class="group no-underline block">
            {p.data.heroImage ? (
              <div class="rounded-xl overflow-hidden mb-5 bg-cream-200 aspect-[16/10] shadow-sm group-hover:shadow-lg transition-shadow duration-300">
                <img src={p.data.heroImage} alt={p.data.title} loading="lazy"
                     class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500" />
              </div>
            ) : (
              <div class="rounded-xl bg-cream-200 aspect-[16/10] mb-5"></div>
            )}
            <h3 class="font-display text-xl text-ink-900 !mt-0 leading-snug group-hover:text-terracotta-600 transition-colors">
              {p.data.title}
            </h3>
            <p class="text-sm text-ink-700 mt-3 leading-relaxed">{p.data.excerpt}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  {featured.length > 0 && (
    <section class="py-10 md:py-14">
      <div class="max-w-6xl mx-auto px-5">
        <div class="bg-cream-100 rounded-[2.5rem] md:rounded-[3rem] shadow-soft px-6 md:px-10 py-14 md:py-20">
          <div class="flex items-end justify-between mb-10">
            <div>
              <p class="text-terracotta-600 text-xs uppercase tracking-[0.2em] font-semibold mb-2">Product reviews</p>
              <h2 class="font-display text-3xl md:text-4xl text-ink-900 leading-tight !mt-0">Top picks this month</h2>
            </div>
            <a href="/products" class="text-sm text-terracotta-600 font-medium whitespace-nowrap hover:underline">All reviews →</a>
          </div>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
            {featured.map((p) => <ProductCard product={p} />)}
          </div>
        </div>
      </div>
    </section>
  )}

  {recentArticles.length > 0 && (
    <section class="max-w-6xl mx-auto px-6 py-20">
      <div class="flex items-end justify-between mb-10">
        <div>
          <p class="text-terracotta-600 text-xs uppercase tracking-[0.2em] font-semibold mb-2">Articles</p>
          <h2 class="font-display text-3xl md:text-4xl text-ink-900 leading-tight">Latest reads</h2>
        </div>
        <a href="/articles" class="text-sm text-terracotta-600 font-medium whitespace-nowrap hover:underline">All articles →</a>
      </div>
      <div class="grid md:grid-cols-3 gap-6 md:gap-8">
        {recentArticles.map((a) => (
          <a href={`/articles/${a.slug}`} class="group no-underline block">
            {a.data.heroImage ? (
              <div class="rounded-xl overflow-hidden mb-4 bg-cream-200 aspect-[16/10] shadow-sm group-hover:shadow-lg transition-shadow duration-300">
                <img src={a.data.heroImage} alt={a.data.title} loading="lazy"
                     class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500" />
              </div>
            ) : (
              <div class="rounded-xl bg-cream-200 aspect-[16/10] mb-4"></div>
            )}
            <h3 class="font-display text-lg text-ink-900 !mt-0 leading-snug group-hover:text-terracotta-600 transition-colors">
              {a.data.title}
            </h3>
            <p class="text-sm text-ink-700 mt-2 leading-relaxed">{a.data.excerpt}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="py-10 md:py-14">
    <div class="max-w-6xl mx-auto px-5">
      <div class="bg-cream-100 rounded-[2.5rem] md:rounded-[3rem] shadow-soft px-6 md:px-10 py-14 md:py-20">
        <div class="grid md:grid-cols-[auto,1fr] gap-8 md:gap-12 items-center max-w-3xl mx-auto">
          <a href={`/authors/${authorSlug}/`} class="block mx-auto md:mx-0 shrink-0 no-underline">
            <img
              src={`/authors/${authorSlug}.svg`}
              alt={b.fullName}
              width="180"
              height="180"
              loading="lazy"
              class="w-40 h-40 md:w-44 md:h-44 rounded-full object-cover shadow-soft ring-4 ring-white"
            />
          </a>
          <div class="text-center md:text-left">
            <p class="text-terracotta-600 text-xs uppercase tracking-[0.2em] font-semibold mb-3">Editorial</p>
            <h2 class="font-display text-3xl md:text-4xl text-ink-900 mb-5 leading-tight !mt-0">
              {home.about.headline}
            </h2>
            <p class="text-ink-700 text-lg leading-relaxed mb-6 max-w-prose">
              {home.about.body}
            </p>
            <div class="flex flex-wrap gap-5 text-sm">
              <a
                href={`/authors/${authorSlug}/`}
                class="text-terracotta-600 font-medium hover:text-terracotta-500 transition-colors no-underline"
              >
                Author page &rarr;
              </a>
              <a href="/methodology/" class="text-terracotta-600 font-medium hover:text-terracotta-500 transition-colors no-underline">
                How we work &rarr;
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-6 py-20">
    <NewsletterForm variant="hero" />
  </section>
</BaseLayout>
