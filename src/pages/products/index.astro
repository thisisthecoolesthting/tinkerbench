---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductCard from '@/components/ProductCard.astro';
import { getCollection } from 'astro:content';

const products = await getCollection('products', ({ data }) => data.status === 'published');

// Only list products that pass the display bar: real image, real price, real rating.
// If any of those are missing, the product isn't ready to ship — hide it.
const complete = products.filter((p) => {
  const d = p.data;
  const hasImage = d.imageUrl && !d.imageUrl.includes('example') && !d.imageUrl.startsWith('data:');
  const hasPrice = typeof d.price === 'number' && d.price > 0;
  const hasRating = typeof d.rating === 'number' && d.rating > 0;
  return hasImage && hasPrice && hasRating;
});

const sorted = complete.sort((a, b) => (b.data.score ?? 0) - (a.data.score ?? 0));

// Group by category for browsing.
const byCategory = sorted.reduce<Record<string, typeof sorted>>((acc, p) => {
  const cat = p.data.category || 'other';
  (acc[cat] = acc[cat] || []).push(p);
  return acc;
}, {});
---

<BaseLayout
  title="Product reviews"
  description="Every product we&rsquo;ve reviewed for women in perimenopause, menopause, and beyond."
>
  <section class="max-w-6xl mx-auto px-5 py-12">
    <h1 class="font-display text-4xl text-ink-900 mb-4">Product reviews</h1>
    <p class="text-ink-700 mb-10 max-w-prose leading-relaxed">
      Sorted by how much real-world difference each product makes for the women we
      recommend it to. Commission has no influence on ranking &mdash; we&rsquo;ve
      turned down great-commission picks that didn&rsquo;t meet our bar.
    </p>

    {Object.entries(byCategory).map(([cat, items]) => (
      <section class="mb-14">
        <h2 class="font-display text-2xl text-ink-900 capitalize mb-5">{cat.replace(/-/g, ' ')}</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
          {items.map((p) => <ProductCard product={p} />)}
        </div>
      </section>
    ))}
  </section>
</BaseLayout>
