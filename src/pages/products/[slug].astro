---
import CompliantLayout from '@/layouts/CompliantLayout.astro';
import AffiliateCTA from '@/components/AffiliateCTA.astro';
import AuthorByline from '@/components/AuthorByline.astro';
import ProductImage from '@/components/ProductImage.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('products', ({ data }) => data.status !== 'draft');
  return products.map((p) => ({
    params: { slug: p.slug },
    props: { product: p },
  }));
}

const { product } = Astro.props;
const { data } = product;
const { Content } = await product.render();

const authorSlug = (data as any).author ?? 'dana-wolff';
const author = await getEntry('authors', authorSlug);

const publishedForByline = (data as any).firstSeen
  ? new Date((data as any).firstSeen)
  : new Date();
const reviewedForByline = (data as any).reviewedAt
  ? new Date((data as any).reviewedAt)
  : ((data as any).lastSeen ? new Date((data as any).lastSeen) : undefined);

const seoTitle = data.seoTitle || `${data.title} Review`;
const seoDesc = data.metaDescription || `TinkerBench review of ${data.title} -- pricing history, refill alternatives, and whether it&rsquo;s worth the current price.`;

const firstSeenDate = (data.firstSeen && data.firstSeen.length >= 10)
  ? data.firstSeen.substring(0, 10)
  : new Date().toISOString().substring(0, 10);

const asin = String(data.asin || product.slug.split('-')[0] || '').toUpperCase();

const productSchema: Record<string, any> = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: data.title,
  description: seoDesc,
  sku: data.asin,
  mpn: data.asin,
  brand: {
    '@type': 'Brand',
    name: 'Amazon',
  },
  url: `https://https://tinkerbench.co/products/${product.slug}`,
};
if (data.imageUrl) productSchema.image = [data.imageUrl];
if (data.price) {
  productSchema.offers = {
    '@type': 'Offer',
    price: data.price.toFixed(2),
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
    url: data.affiliateUrl,
    priceValidUntil: new Date(Date.now() + 30 * 86400000).toISOString().substring(0, 10),
    seller: {
      '@type': 'Organization',
      name: 'Amazon',
    },
  };
}

productSchema.review = {
  '@type': 'Review',
  author: author ? {
    '@type': 'Person',
    '@id': `https://https://tinkerbench.co/authors/${author.slug}/#person`,
    name: author.data.name,
    url: `https://https://tinkerbench.co/authors/${author.slug}/`,
    jobTitle: author.data.role,
  } : {
    '@type': 'Organization',
    name: 'TinkerBench',
  },
  publisher: {
    '@type': 'Organization',
    name: 'TinkerBench',
    url: 'https://https://tinkerbench.co',
  },
  datePublished: firstSeenDate,
  reviewBody: seoDesc,
  reviewRating: {
    '@type': 'Rating',
    ratingValue: data.rating ? data.rating.toFixed(1) : '4.0',
    bestRating: '5',
    worstRating: '1',
  },
};

if (data.rating && data.reviewCount) {
  productSchema.aggregateRating = {
    '@type': 'AggregateRating',
    ratingValue: data.rating.toFixed(1),
    reviewCount: data.reviewCount,
    bestRating: '5',
    worstRating: '1',
  };
}
---

<CompliantLayout
  title={seoTitle}
  description={seoDesc}
  image={data.imageUrl}
  sectionAds="product"
>
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />

  <article class="max-w-site mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-14">
    <div class="max-w-3xl mx-auto">
      <header class="mb-6 text-center">
        <p class="text-sm text-ink-500 uppercase tracking-wider mb-2">{data.category.replace(/-/g, ' ')}</p>
        <h1 class="font-display text-3xl md:text-4xl mb-4 text-ink-900 !mt-0">{data.title}</h1>
        <div class="flex flex-wrap gap-4 justify-center text-sm text-ink-700">
          {data.price && <span><strong>${data.price.toFixed(2)}</strong></span>}
          {data.rating && <span>&#9733; {data.rating.toFixed(1)} {data.reviewCount && `(${data.reviewCount.toLocaleString()})`}</span>}
          {data.isPrime && <span class="text-sage-600">Prime eligible</span>}
        </div>
      </header>

      <div class="mb-6 text-left">
        <AuthorByline
          authorSlug={authorSlug}
          publishedAt={publishedForByline}
          reviewedAt={reviewedForByline}
        />
      </div>

      <figure class="bg-cream-100 rounded-3xl p-8 mb-8 flex items-center justify-center aspect-square max-w-md mx-auto">
        <ProductImage
          slug={product.slug}
          asin={asin}
          imageUrl={data.imageUrl}
          alt={data.title}
          loading="eager"
          class="max-h-72 w-full object-contain"
        />
      </figure>

      <div class="prose prose-base md:prose-lg prose-ink max-w-none text-left">
        <Content />
      </div>

      <div class="mt-8 not-prose">
        <AffiliateCTA asin={data.asin} url={data.affiliateUrl} label="See it on Amazon" />
      </div>

      <p class="text-xs text-ink-500 mt-10">
        Reviewed by <a href={`/authors/${authorSlug}/`} class="text-terracotta-600 hover:underline">{author?.data.name ?? 'the TinkerBench team'}</a>.
        Last checked: {data.lastSeen ? new Date(data.lastSeen).toLocaleDateString() : '&mdash;'}.
        Prices and availability change. We earn a commission on qualifying purchases.
        <a href="/methodology/" class="text-terracotta-600 hover:underline"> How we research &rarr;</a>
      </p>
    </div>
  </article>
</CompliantLayout>
