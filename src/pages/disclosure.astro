---
import BaseLayout from '@/layouts/BaseLayout.astro';
import home from '@/data/spawn-home.json';
const b = home.brand;
const support = (home as { supportEmail?: string }).supportEmail;
---

<BaseLayout
  title={`How we keep the lights on — ${b.fullName}`}
  description="How we earn and how that affects what we cover."
  ogType="website"
>
  <article class="prose prose-lg prose-ink max-w-3xl mx-auto py-16 px-5">
    <h1 class="font-display text-4xl text-ink-900 !mt-0">How we keep the lights on</h1>
    <p>
      {b.fullName} may earn a commission from qualifying purchases through retailer links, including
      the Amazon Services LLC Associates Program, when you use our links. You pay the same
      price; the retailer may share a small fee with us.
    </p>
    <p>
      Coverage is selected by editors; we do not accept payment for a positive review. When we
      are unsure about a product, we say so. See <a href="/methodology">how we work</a> for
      more detail.
    </p>
    <p>
      Questions: <a href={`mailto:${support}`}>{support}</a>
    </p>
  </article>
</BaseLayout>
