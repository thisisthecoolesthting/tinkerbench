# Public env vars. The PUBLIC_ prefix exposes them to client-side code.
PUBLIC_ASSOCIATE_TAG=refillwatch-20

# Newsletter form endpoint. Paste your Beehiiv embed URL here once the
# publication exists. Looks like:
#   https://api.beehiiv.com/v2/publications/pub_xxxxx/subscriptions
# Or for ConvertKit:
#   https://app.convertkit.com/forms/xxxxxxxxx/subscriptions
# Until set, the form falls back to a mailto: link.
PUBLIC_NEWSLETTER_EMBED_URL=

# Used by scout/generate.py when invoked from this folder.
# (the scout itself reads these from your shell env, not this file)
